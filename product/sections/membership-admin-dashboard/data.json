{
  "_meta": {
    "models": {
      "DashboardStats": "Summary statistics displayed on the dashboard overview — total members, active volunteers, pending renewals, and new signups this month.",
      "MemberListItem": "A row in the members table with key fields for filtering and display. Links to the full MemberDetail.",
      "MemberDetail": "The complete editable record for a single member including contact info, address, membership info, payment history, and volunteer roles with certification status.",
      "ActivityLogEntry": "A timestamped record of a membership data change shown in the activity feed.",
      "AdminMessage": "A message in the admin flat message list — can be sent or received, with subject, body, and status.",
      "LeadDashboard": "A scoped mini-dashboard for a lead's volunteer role group with group stats and a subordinate roster."
    },
    "relationships": [
      "DashboardStats aggregates data across all MemberListItems",
      "MemberListItem is a summary view of MemberDetail",
      "ActivityLogEntry references a MemberDetail by memberId",
      "AdminMessage references a MemberDetail as sender or recipient",
      "LeadDashboard contains a filtered subset of MemberListItems for one volunteer role"
    ]
  },
